{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "OpenSync": "Information"
    }
  },
  "OpenSync": {
    "Database": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=opensync-demo.db"
    },
    "Limits": {
      "MaxDocumentSizeBytes": 65536,
      "MaxListItems": 100,
      "MaxMapItems": 100,
      "DefaultRateLimitPerSecond": 1000
    }
  }
}
