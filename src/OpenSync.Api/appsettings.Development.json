{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    }
  },
  "OpenSync": {
    "Database": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=opensync_dev.db"
    }
  }
}
